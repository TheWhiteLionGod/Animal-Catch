<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <!-- ══ ENEMY HUD (top) ══════════════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_enemy"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#1A1A2E"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:strokeColor="#E94560"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_enemy_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enemy"
                    android:textColor="#E94560"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:text="WILD"
                    android:textColor="#E94560"
                    android:textSize="11sp"
                    android:background="@drawable/badge_bg_red"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/pb_enemy_hp"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="6dp"
                android:progressTint="#E94560"
                android:progressBackgroundTint="#333333"
                android:max="100"
                android:progress="100" />

            <TextView
                android:id="@+id/tv_enemy_hp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="HP: ?"
                android:textColor="#CCCCCC"
                android:textSize="13sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ══ PLAYER HUD (below enemy) ════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_player"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#1A2E1A"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:strokeColor="#4CAF50"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/card_enemy"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_player_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Your Animal"
                    android:textColor="#4CAF50"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_player_level"
                    android:text="Lv.1"
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    android:background="@drawable/badge_bg_green"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/pb_player_hp"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="6dp"
                android:progressTint="#4CAF50"
                android:progressBackgroundTint="#333333"
                android:max="100"
                android:progress="100" />

            <TextView
                android:id="@+id/tv_player_hp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="HP: ?"
                android:textColor="#CCCCCC"
                android:textSize="13sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ══ BATTLE LOG ═══════════════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/scroll_log"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:background="#111111"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/card_player"
        app:layout_constraintBottom_toTopOf="@id/btn_attack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_battle_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingExtra="4dp"
            android:text=""
            android:textColor="#DDDDDD"
            android:textSize="13sp" />
    </ScrollView>

    <!-- ══ ACTION BUTTONS ═══════════════════════════════════════════════════ -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_attack"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_margin="8dp"
        android:text="⚔️ Attack"
        android:textSize="16sp"
        app:backgroundTint="#E94560"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_defend"
        app:layout_constraintWidth_percent="0.4" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_defend"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_margin="8dp"
        android:layout_marginBottom="48dp"
        android:text="🛡️ Defend"
        android:textSize="16sp"
        app:backgroundTint="#1565C0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_flee"
        app:layout_constraintStart_toEndOf="@id/btn_attack"
        app:layout_constraintWidth_percent="0.4" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_flee"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_margin="8dp"
        android:text="🏃"
        android:textSize="20sp"
        app:backgroundTint="#444444"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_defend"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Loading overlay while fetching enemy stats -->
    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="#4CAF50" />

        <TextView
            android:layout_marginTop="12dp"
            android:text="Finding opponent…"
            android:textColor="@android:color/white"
            android:textSize="15sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>